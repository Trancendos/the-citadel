{
  "name": "@trancendos/the-citadel",
  "version": "1.0.0",
  "description": "Defense and protection",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "audit:deps": "pnpm audit --audit-level=high",
    "deps:policy": "node scripts/check-dependency-policy.mjs",
    "security:check": "pnpm audit --audit-level=high && node scripts/check-dependency-policy.mjs"
  },
  "author": "Trancendos",
  "license": "MIT",
  "engines": {
    "node": ">=20 <23"
  },
  "packageManager": "pnpm@10.26.0",
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
